{
  "name": "app",
  "version": "1.0.0",
  "description": "A 3D interactive solar system simulator built with JavaScript and Three.js. This project provides a dynamic visualization of our solar system, allowing users to explore the planets, their moons, and other celestial phenomena.",
  "main": "main.js",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/therealsahil19/solarsystemsim25.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/therealsahil19/solarsystemsim25/issues"
  },
  "homepage": "https://github.com/therealsahil19/solarsystemsim25#readme",
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@playwright/test": "^1.55.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "three": "^0.179.1",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!three/.*)"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(gif|ttf|eot|svg|png)$": "<rootDir>/__mocks__/fileMock.js"
    }
  }
}
